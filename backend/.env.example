# ============================================================================
# CreatorStore — Backend environment
# Copy to `.env` and fill in values:   cp .env.example .env
# Validated on boot (src/config/env.ts); the server refuses to start if a
# REQUIRED value is missing or malformed.
# ============================================================================

# ---- Core ----
NODE_ENV=development                    # development | test | production
PORT=4000
# Comma-separated list of allowed browser origins (the frontend)
CORS_ORIGINS=http://localhost:3000
# Public base URL of the frontend, used to build links in emails
APP_URL=http://localhost:3000

# ---- Database (REQUIRED) ----
# Local:  mongodb://127.0.0.1:27017/creatorstore
# Atlas:  mongodb+srv://USER:PASS@cluster.xxxx.mongodb.net/creatorstore
MONGODB_URI=mongodb://127.0.0.1:27017/creatorstore

# ---- Auth / JWT (REQUIRED — each secret must be at least 16 chars) ----
# Generate strong secrets:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret-min-16-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16-chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
# Set to true in production (requires HTTPS) so the refresh cookie is Secure
COOKIE_SECURE=false

# ---- Cloudinary (OPTIONAL — uploads disabled if blank) ----
# Needed for product covers, avatars, course videos, fulfilment files.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Email / Resend (OPTIONAL — emails are logged to console if blank) ----
# Needed to deliver verification, broadcasts, receipts, and flow emails.
# NOTE: when blank in non-production, email-verification gating is bypassed.
RESEND_API_KEY=
EMAIL_FROM="CreatorStore <onboarding@example.com>"

# ---- Stripe (OPTIONAL — checkout runs in DEMO mode if blank in non-prod) ----
# Needed for real payments + Connect payouts. In dev without these, checkout
# simulates a completed purchase so the full purchase→fulfilment flow is testable.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
