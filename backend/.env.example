# ============================================================================
# CreatorStore — Backend environment
# Copy to `.env` and fill in values:   cp .env.example .env
# Validated on boot (src/config/env.ts); the server refuses to start if a
# REQUIRED value is missing or malformed.
# ============================================================================

# ---- Core ----
NODE_ENV=development                    # development | test | production
PORT=4000
# Comma-separated list of allowed browser origins (the frontend)
CORS_ORIGINS=http://localhost:3000
# Public base URL of the frontend, used to build links in emails
APP_URL=http://localhost:3000

# ---- Database (REQUIRED) ----
# Local:  mongodb://127.0.0.1:27017/creatorstore
# Atlas:  mongodb+srv://USER:PASS@cluster.xxxx.mongodb.net/creatorstore
MONGODB_URI=mongodb://127.0.0.1:27017/creatorstore

# ---- Auth / JWT (REQUIRED — each secret must be at least 16 chars) ----
# Generate strong secrets:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret-min-16-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16-chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
# Set to true in production (requires HTTPS) so the refresh cookie is Secure
COOKIE_SECURE=false

# ---- Cloudinary (OPTIONAL — uploads disabled if blank) ----
# Needed for product covers, avatars, course videos, fulfilment files.
CLOUDINARY_CLOUD_NAME=dey3w0hhu
CLOUDINARY_API_KEY=388353646376656
CLOUDINARY_API_SECRET=AttKXTz7VQ_f2r7HBeAMDEkS2-8

# ---- Email / Resend (OPTIONAL — emails are logged to console if blank) ----
# Needed to deliver verification, broadcasts, receipts, and flow emails.
# NOTE: when blank in non-production, email-verification gating is bypassed.
RESEND_API_KEY=re_d6HEpWRr_5BH6xja7UdYg1wd9yk8Q9tLB
EMAIL_FROM="CreatorStore <support@creatorstore.com>"

# ---- Stripe (OPTIONAL — checkout runs in DEMO mode if blank in non-prod) ----
# Needed for real payments + Connect payouts. In dev without these, checkout
# simulates a completed purchase so the full purchase→fulfilment flow is testable.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Stanley AI assistant (OPTIONAL — deterministic fallback if blank) ----
# https://console.anthropic.com/ → API Keys
ANTHROPIC_API_KEY=
ASSISTANT_MODEL=claude-sonnet-4-6

# ---- Instagram AutoDM (OPTIONAL — simulation mode if App ID/Secret blank) ----
# Uses the "Instagram API with Instagram Login" flow (same as stan.store): the
# creator authorizes with their Instagram credentials directly — no Facebook
# Page required. Create an app at https://developers.facebook.com/, add the
# Instagram use case, and open "API setup with Instagram login" to find the
# Instagram app ID + secret. With these set, the AutoDM "Connect Instagram"
# button runs real OAuth and replies are delivered via the Graph API webhook.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_GRAPH_VERSION=v21.0
# Instagram rejects http://localhost — must be a public HTTPS URL. Register the
# SAME value under "Set up Instagram business login → Redirect URI". In local
# dev use a tunnel, e.g. https://<host>.trycloudflare.com/api/integrations/instagram/callback
INSTAGRAM_REDIRECT_URI=http://localhost:4000/api/integrations/instagram/callback
# Any string you choose; enter the SAME value in the Instagram webhook setup screen.
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
