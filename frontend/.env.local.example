# ============================================================================
# CreatorStore — Frontend environment
# Copy to `.env.local`:   cp .env.local.example .env.local
# Only NEXT_PUBLIC_* vars are exposed to the browser.
# ============================================================================

# Browser-facing base URL of the backend API.
# Local dev:    http://localhost:5000
# Production:   https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:5000

# Base URL for Stan Affiliate Link products (optional — default join.stan.store)
NEXT_PUBLIC_STAN_AFFILIATE_JOIN_URL=https://join.stan.store
